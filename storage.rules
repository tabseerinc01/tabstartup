rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for all profile images
    match /profile-images/{userId}/{allPaths=**} {
      allow read: if true;
      // Allow write only if authenticated and the folder belongs to the user
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny all other writes, allow authenticated reads
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}