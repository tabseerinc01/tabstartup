
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'shahmubaruk05@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'super_admin'])
        ))
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /referrals/{referralId} {
      allow read: if request.auth != null && (resource.data.referrerUid == request.auth.uid || resource.data.referredUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      // Allow referred user to update completion status and referrer to update reward status
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.referredUid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referredProfileCompleted'])) ||
        (request.auth.uid == resource.data.referrerUid && request.resource.data.diff(resource.data).affectedKeys().hasAny(['rewardGranted', 'rewardGrantedAt'])) ||
        isAdmin()
      );
    }

    match /venturePitches/{pitchId} {
      allow read: if request.auth != null && (resource.data.senderUid == request.auth.uid || resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow get, list: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }
    
    match /deals/{dealId} {
      allow get, list: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());

      match /notes/{noteId} { allow read, write: if request.auth != null; }
      match /activities/{activityId} { allow read, write: if request.auth != null; }
    }

    match /invoices/{invoiceId} {
      allow get: if true;
      allow list: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /tasks/{taskId} {
      allow get, list: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerUid == request.auth.uid || isAdmin());
      match /activities/{activityId} { allow read, write: if request.auth != null; }
    }

    match /connections/{connectionId} {
      allow read: if request.auth != null && (resource.data.initiatorUid == request.auth.uid || resource.data.recipientUid == request.auth.uid || isAdmin());
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.recipientUid == request.auth.uid || resource.data.initiatorUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    
    match /communityPostLikes/{likeId} { allow read: if true; allow write: if request.auth != null; }
    match /communityComments/{commentId} { allow read: if true; allow write: if request.auth != null; }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }

    match /chats/{chatId} {
      allow read, update: if request.auth != null && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin());
      allow create: if request.auth != null;
      match /messages/{messageId} { allow read, create: if request.auth != null; }
    }

    match /startups/{startupId} {
      allow read: if true;
      allow create, update: if request.auth != null && (request.auth.uid == startupId || isAdmin());
      allow delete: if isAdmin();
      match /views/{viewId} { allow read: if true; allow create: if true; }
      match /interests/{interestId} { allow read: if true; allow create, update: if request.auth != null; }
    }

    match /services/{serviceId} { allow read: if true; allow write: if request.auth != null; }
    match /seoPages/{pageId} { allow read: if true; allow write: if isAdmin(); }
    
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null && isAdmin();
    }
  }
}
