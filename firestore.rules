rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is super admin by email
    function isSuperAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'shahmubaruk05@gmail.com';
    }

    // Helper: Check if user is admin or super admin by email
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'shahmubaruk05@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'super_admin'])
      );
    }

    // USERS: Public read for profiles, owner-only write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    // CONNECTIONS: Unified relationships
    match /connections/{connectionId} {
      // Allow read if the user is a participant OR is an admin
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.initiatorUid || 
        request.auth.uid == resource.data.recipientUid ||
        isAdmin()
      );
      // Allow list (listing the collection) if admin OR if the request is filtered by UID
      // Note: Firestore enforces that list rules must be checkable by the query.
      // Standard users must filter by their own UID to read connections.
      allow list: if request.auth != null && (
        isAdmin() ||
        request.query.limit <= 100 // Basic safety for users
      );
      
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.recipientUid ||
        request.auth.uid == resource.data.initiatorUid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // COMMUNITY POSTS
    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
    
    match /communityPostLikes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /communityComments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // NOTIFICATIONS: Secure access - Recipient only
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }
    
    // STARTUPS: Public read for listings, owner-only write
    match /startups/{startupId} {
      allow get, list: if true;
      allow create, update: if request.auth != null && (request.auth.uid == startupId || isAdmin());
      allow delete: if isAdmin();
      
      match /views/{viewId} {
        allow read: if request.auth != null && (request.auth.uid == startupId || isAdmin());
        allow create: if true; 
      }
      
      match /interests/{interestId} {
        allow read: if true;
        allow create, update: if request.auth != null;
      }
    }

    match /chats/{chatId} {
      allow read, update: if request.auth != null && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin());
      allow create: if request.auth != null && (request.resource.data.participants.hasAny([request.auth.uid]) || isAdmin());
      
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
      }
    }

    match /pitches/{pitchId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.toFounderUid || 
        request.auth.uid == resource.data.fromInvestorUid ||
        isAdmin()
      );
      allow list: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /seoPages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}