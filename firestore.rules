
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: Public read for profiles, owner-only write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // STARTUPS: Public read for listings, owner-only write
    match /startups/{startupId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == startupId;
    }
    
    // CHATS: Only participants can access
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // PITCHES (Interest Requests)
    match /pitches/{pitchId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == resource.data.toFounderUid
               || request.auth.uid == resource.data.fromInvestorUid);
      allow update: if request.auth != null && request.auth.uid == resource.data.toFounderUid;
    }
  }
}
