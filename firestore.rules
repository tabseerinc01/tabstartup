
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TABSTARTUP SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidLink(field, value) {
      return request.resource.data[field] == value;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && isValidLink('uid', userId);
      allow update: if isExistingOwner(userId) && isImmutable('uid');
      allow delete: if isExistingOwner(userId);
    }

    match /startups/{startupId} {
      allow get, list: if true;
      allow create: if isOwner(startupId) && isValidLink('ownerUid', startupId);
      allow update: if isExistingOwner(startupId) && isImmutable('ownerUid');
      allow delete: if isExistingOwner(startupId);

      match /views/{viewId} {
        allow create: if true;
        allow list: if isOwner(startupId);
      }

      match /interests/{investorId} {
        // Any signed in user with investor role can create an interest
        // We assume the caller checks the role, but for rules we simplify
        allow create: if isSignedIn() && request.auth.uid == investorId;
        allow get: if isSignedIn() && (request.auth.uid == investorId || isOwner(startupId));
        allow list: if isOwner(startupId);
      }
    }
  }
}
