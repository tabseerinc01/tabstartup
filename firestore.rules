rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: Public read for profiles, owner-only write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // STARTUPS: Public read for listings, owner-only write
    match /startups/{startupId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == startupId;
      
      // Subcollections for tracking
      match /views/{viewId} {
        allow read: if request.auth != null && request.auth.uid == startupId;
        allow create: if true; 
      }
      
      match /interests/{interestId} {
        allow read: if request.auth != null && request.auth.uid == startupId;
        allow write: if request.auth != null;
      }
    }
    
    // CHATS: Only participants can access
    match /chats/{chatId} {
      // Allow read/update if the user is a participant
      allow read, update: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      
      // Allow create if the user is one of the participants
      allow create: if request.auth != null && request.resource.data.participants.hasAny([request.auth.uid]);
      
      match /messages/{messageId} {
        // Allow read/create if the user is a participant of the parent chat
        allow read, create: if request.auth != null && 
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }

    // PITCHES (Interest Requests)
    match /pitches/{pitchId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.toFounderUid || 
        request.auth.uid == resource.data.fromInvestorUid
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.toFounderUid || 
        request.auth.uid == resource.data.fromInvestorUid
      );
    }
  }
}