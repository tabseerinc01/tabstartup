
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier matching the Firebase Auth UID."
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["founder", "mentor", "investor"]
        },
        "headline": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "whyBuilding": {
          "type": "string",
          "description": "Long-form text explaining the motivation behind the startup."
        },
        "location": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": ["Idea", "Early", "Growth", "Scaling", ""]
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lookingFor": {
          "type": "string"
        },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "company": { "type": "string" },
              "role": { "type": "string" },
              "duration": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "school": { "type": "string" },
              "degree": { "type": "string" },
              "year": { "type": "string" }
            }
          }
        },
        "achievements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "website": { "type": "string" },
            "twitter": { "type": "string" }
          }
        },
        "availability": {
          "type": "object",
          "properties": {
            "openToInvestment": { "type": "boolean" },
            "hiring": { "type": "boolean" },
            "coFounder": { "type": "boolean" }
          }
        },
        "isVerified": {
          "type": "boolean",
          "default": false
        },
        "preferredStage": {
          "type": "string"
        },
        "investorNote": {
          "type": "string"
        },
        "isOpenToPitches": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "fullName", "email", "role", "createdAt", "updatedAt"]
    },
    "Startup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Startup",
      "type": "object",
      "description": "Represents a startup listing created by a Founder.",
      "properties": {
        "ownerUid": {
          "type": "string",
          "description": "The UID of the founder who owns this startup."
        },
        "name": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "fundingNeed": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pitchDeckUrl": {
            "type": "string",
            "description": "Link to the pitch deck document."
        },
        "equityOffered": {
            "type": "string",
            "description": "Percentage of equity offered for the target funding."
        },
        "fundraisingStatus": {
            "type": "string",
            "enum": ["Open", "Closed", "Paused"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerUid", "name", "createdAt", "updatedAt"]
    },
    "View": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "View",
      "type": "object",
      "description": "Tracks a single view of a startup profile.",
      "properties": {
        "startupId": { "type": "string" },
        "viewerId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["startupId", "timestamp"]
    },
    "Interest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Interest",
      "type": "object",
      "description": "Tracks investor interest in a startup.",
      "properties": {
        "startupId": { "type": "string" },
        "investorId": { "type": "string" },
        "investorName": { "type": "string" },
        "investorHeadline": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["startupId", "investorId", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Main user profile collection. Stores personal info and roles."
        }
      },
      {
        "path": "/startups/{startupId}",
        "definition": {
          "entityName": "Startup",
          "schema": { "$ref": "#/backend/entities/Startup" },
          "description": "Startup listings. Each founder has one startup, where startupId is the ownerUid."
        }
      },
      {
        "path": "/startups/{startupId}/views/{viewId}",
        "definition": {
          "entityName": "View",
          "schema": { "$ref": "#/backend/entities/View" },
          "description": "Tracks views for a specific startup."
        }
      },
      {
        "path": "/startups/{startupId}/interests/{investorId}",
        "definition": {
          "entityName": "Interest",
          "schema": { "$ref": "#/backend/entities/Interest" },
          "description": "Tracks specific investor interest in a startup."
        }
      }
    ]
  }
}
