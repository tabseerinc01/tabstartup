
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "primaryRole": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "plan": { "type": "string", "enum": ["basic", "pro", "growth"], "default": "basic" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "past_due"], "default": "inactive" },
        "referralCode": { "type": "string", "description": "Unique referral code for the user." },
        "referralCount": { "type": "number", "default": 0, "description": "Number of successful referrals." },
        "imageUrl": { "type": "string" },
        "coverImageUrl": { "type": "string" },
        "headline": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "website": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "createdAt", "updatedAt"]
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "description": "Records a successful sign-up through a referral link.",
      "properties": {
        "referrerUid": { "type": "string" },
        "referredUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerUid", "referredUid", "createdAt"]
    },
    "Startup": {
      "title": "Startup",
      "type": "object",
      "description": "A venture profile listed on the platform.",
      "properties": {
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string", "description": "SEO friendly URL identifier." },
        "shortDescription": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "hidden"] },
        "featured": { "type": "boolean" },
        "startupVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "name", "slug", "status"]
    },
    "VenturePitch": {
      "title": "VenturePitch",
      "type": "object",
      "description": "A startup opportunity submission from a founder to an investor.",
      "properties": {
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "recipientUid": { "type": "string" },
        "startupId": { "type": "string" },
        "startupName": { "type": "string" },
        "pitchMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "recipientUid", "status", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "contactName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deal": {
      "title": "Deal",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "title": { "type": "string" },
        "stage": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "invoiceNumber": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/referrals/{referralId}",
        "definition": { "entityName": "Referral", "schema": { "$ref": "#/backend/entities/Referral" }, "description": "Tracks signups via referral." }
      },
      {
        "path": "/startups/{startupId}",
        "definition": { "entityName": "Startup", "schema": { "$ref": "#/backend/entities/Startup" }, "description": "Venture listings." }
      },
      {
        "path": "/venturePitches/{pitchId}",
        "definition": { "entityName": "VenturePitch", "schema": { "$ref": "#/backend/entities/VenturePitch" }, "description": "Startup pitches to investors." }
      },
      {
        "path": "/contacts/{contactId}",
        "definition": { "entityName": "Contact", "schema": { "$ref": "#/backend/entities/Contact" }, "description": "Private contact records." }
      },
      {
        "path": "/deals/{dealId}",
        "definition": { "entityName": "Deal", "schema": { "$ref": "#/backend/entities/Deal" }, "description": "Private pipeline deals." }
      },
      {
        "path": "/invoices/{invoiceId}",
        "definition": { "entityName": "Invoice", "schema": { "$ref": "#/backend/entities/Invoice" }, "description": "Private billing invoices." }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": { "entityName": "Task", "schema": { "$ref": "#/backend/entities/Task" }, "description": "Private workspace tasks." }
      }
    ]
  }
}
