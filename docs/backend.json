
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier matching the Firebase Auth UID."
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["founder", "mentor", "investor"]
        },
        "headline": {
          "type": "string"
        },
        "investorHeadline": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "investorBio": {
          "type": "string"
        },
        "whyBuilding": {
          "type": "string",
          "description": "Long-form text explaining the motivation behind the startup."
        },
        "location": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": ["Idea", "Early", "Growth", "Scaling", ""]
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lookingFor": {
          "type": "string"
        },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "company": { "type": "string" },
              "role": { "type": "string" },
              "duration": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "school": { "type": "string" },
              "degree": { "type": "string" },
              "year": { "type": "string" }
            }
          }
        },
        "achievements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "website": { "type": "string" },
            "twitter": { "type": "string" }
          }
        },
        "linkedinUrl": {
          "type": "string"
        },
        "availability": {
          "type": "object",
          "properties": {
            "openToInvestment": { "boolean": true },
            "hiring": { "boolean": true },
            "coFounder": { "boolean": true }
          }
        },
        "isVerified": {
          "type": "boolean",
          "default": false
        },
        "preferredStage": {
          "type": "array",
          "items": { "type": "string" }
        },
        "investmentFocus": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ticketSize": {
          "type": "string"
        },
        "investorNote": {
          "type": "string"
        },
        "isOpenToPitches": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "fullName", "email", "role", "createdAt", "updatedAt"]
    },
    "Startup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Startup",
      "type": "object",
      "description": "Represents a startup listing created by a Founder.",
      "properties": {
        "ownerUid": {
          "type": "string",
          "description": "The UID of the founder who owns this startup."
        },
        "name": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "fundingNeed": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pitchDeckUrl": {
            "type": "string",
            "description": "Link to the pitch deck document."
        },
        "equityOffered": {
            "type": "string",
            "description": "Percentage of equity offered for the target funding."
        },
        "fundraisingStatus": {
            "type": "string",
            "enum": ["Open", "Closed", "Paused"]
        },
        "problem": {
          "type": "string",
          "description": "The problem the startup is solving."
        },
        "solution": {
          "type": "string",
          "description": "The solution the startup provides."
        },
        "targetMarket": {
          "type": "string",
          "description": "The target audience or customers."
        },
        "businessModel": {
          "type": "string",
          "description": "How the startup plans to make money."
        },
        "traction": {
          "type": "string",
          "description": "Key metrics or proof of growth."
        },
        "teamInfo": {
          "type": "string",
          "description": "Information about the founding team."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerUid", "name", "createdAt", "updatedAt"]
    },
    "Chat": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Chat",
      "type": "object",
      "description": "A conversation between two users.",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "View": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "View",
      "type": "object",
      "description": "Tracks a single view of a startup profile.",
      "properties": {
        "startupId": { "type": "string" },
        "viewerId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["startupId", "timestamp"]
    },
    "Interest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Interest",
      "type": "object",
      "description": "Tracks investor interest in a startup.",
      "properties": {
        "startupId": { "type": "string" },
        "investorId": { "type": "string" },
        "investorName": { "type": "string" },
        "investorHeadline": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["startupId", "investorId", "timestamp"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "A private message within a chat.",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Pitch": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Pitch",
      "type": "object",
      "description": "A pitch sent from an investor to a founder.",
      "properties": {
        "fromInvestorUid": { "type": "string" },
        "toFounderUid": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromInvestorUid", "toFounderUid", "message", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Main user profile collection."
        }
      },
      {
        "path": "/startups/{startupId}",
        "definition": {
          "entityName": "Startup",
          "schema": { "$ref": "#/backend/entities/Startup" },
          "description": "Startup listings."
        }
      },
      {
        "path": "/chats/{chatId}",
        "definition": {
          "entityName": "Chat",
          "schema": { "$ref": "#/backend/entities/Chat" },
          "description": "Conversations between users."
        }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Messages within a chat."
        }
      },
      {
        "path": "/pitches/{pitchId}",
        "definition": {
          "entityName": "Pitch",
          "schema": { "$ref": "#/backend/entities/Pitch" },
          "description": "Investment interest requests."
        }
      }
    ]
  }
}
