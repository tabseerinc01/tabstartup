
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier matching the Firebase Auth UID."
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["founder", "mentor", "investor", "user", "admin", "super_admin"],
          "description": "Legacy field for backward compatibility."
        },
        "primaryRole": {
          "type": "string",
          "enum": ["founder", "mentor", "investor", "user", "admin", "super_admin"]
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of active roles for this user."
        },
        "headline": {
          "type": "string"
        },
        "investorHeadline": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "investorBio": {
          "type": "string"
        },
        "whyBuilding": {
          "type": "string",
          "description": "Long-form text explaining the motivation behind the startup."
        },
        "location": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": ["Idea", "Early", "Growth", "Scaling", ""]
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lookingFor": {
          "type": "string"
        },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "company": { "type": "string" },
              "role": { "type": "string" },
              "duration": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "school": { "type": "string" },
              "degree": { "type": "string" },
              "year": { "type": "string" }
            }
          }
        },
        "achievements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "website": { "type": "string" },
            "twitter": { "type": "string" }
          }
        },
        "linkedinUrl": {
          "type": "string"
        },
        "availability": {
          "type": "object",
          "properties": {
            "openToInvestment": { "type": "boolean" },
            "hiring": { "type": "boolean" },
            "coFounder": { "type": "boolean" }
          }
        },
        "lookingForCofounder": {
          "type": "boolean",
          "default": false
        },
        "cofounderSkills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cofounderRole": {
          "type": "string",
          "description": "The specific role needed (e.g., CTO, COO, Head of Growth)."
        },
        "equityOffer": {
          "type": "string",
          "description": "The range of equity offered (e.g., 10-25%)."
        },
        "commitmentType": {
          "type": "string",
          "enum": ["Full-time", "Part-time", "Equity-only", "Other", ""],
          "description": "Expected commitment level."
        },
        "isVerified": {
          "type": "boolean",
          "default": false
        },
        "preferredStage": {
          "type": "array",
          "items": { "type": "string" }
        },
        "investmentFocus": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ticketSize": {
          "type": "string"
        },
        "investorNote": {
          "type": "string"
        },
        "isOpenToPitches": {
          "type": "boolean"
        },
        "isMentor": {
          "type": "boolean",
          "default": false,
          "description": "Whether the user is an active mentor."
        },
        "mentorSkills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific areas where the mentor provides guidance."
        },
        "mentorBio": {
          "type": "string",
          "description": "A dedicated bio for mentorship purposes."
        },
        "yearsOfExperience": {
          "type": "string",
          "description": "The number of years of professional experience."
        },
        "mentorAvailability": {
          "type": "string",
          "description": "Mentorship schedule or availability details (e.g. '2 hours/week')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "fullName", "email", "role", "createdAt", "updatedAt"]
    },
    "CommunityPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunityPost",
      "type": "object",
      "description": "A post in the startup community feed.",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorImage": { "type": "string" },
        "authorType": { "type": "string", "enum": ["founder", "investor", "mentor", "user"] },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number", "default": 0 },
        "commentsCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "default": "active" },
        "startupName": { "type": "string" },
        "startupId": { "type": "string" }
      },
      "required": ["authorUid", "authorName", "authorType", "content", "createdAt", "status"]
    },
    "CommunityPostLike": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunityPostLike",
      "type": "object",
      "description": "A record of a user liking a community post.",
      "properties": {
        "postId": { "type": "string" },
        "userUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userUid", "createdAt"]
    },
    "CommunityComment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunityComment",
      "type": "object",
      "description": "A comment on a community post.",
      "properties": {
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorImage": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorUid", "authorName", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Main user profile collection."
        }
      },
      {
        "path": "/communityPosts/{postId}",
        "definition": {
          "entityName": "CommunityPost",
          "schema": { "$ref": "#/backend/entities/CommunityPost" },
          "description": "Startup community feed posts."
        }
      },
      {
        "path": "/communityPostLikes/{likeId}",
        "definition": {
          "entityName": "CommunityPostLike",
          "schema": { "$ref": "#/backend/entities/CommunityPostLike" },
          "description": "Tracks likes on community posts."
        }
      },
      {
        "path": "/communityComments/{commentId}",
        "definition": {
          "entityName": "CommunityComment",
          "schema": { "$ref": "#/backend/entities/CommunityComment" },
          "description": "Comments on community posts."
        }
      }
    ]
  }
}
