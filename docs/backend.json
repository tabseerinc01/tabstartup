
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier matching the Firebase Auth UID."
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["founder", "mentor", "investor"]
        },
        "headline": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": ["Idea", "Early", "Growth", "Scaling", ""]
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lookingFor": {
          "type": "string"
        },
        "preferredStage": {
          "type": "string"
        },
        "investorNote": {
          "type": "string"
        },
        "isOpenToPitches": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "fullName", "email", "role", "createdAt", "updatedAt"]
    },
    "Startup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Startup",
      "type": "object",
      "description": "Represents a startup listing created by a Founder.",
      "properties": {
        "ownerUid": {
          "type": "string",
          "description": "The UID of the founder who owns this startup."
        },
        "name": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "fundingNeed": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerUid", "name", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Main user profile collection. Stores personal info and roles."
        }
      },
      {
        "path": "/startups/{startupId}",
        "definition": {
          "entityName": "Startup",
          "schema": { "$ref": "#/backend/entities/Startup" },
          "description": "Startup listings. Each founder has one startup, where startupId is the ownerUid."
        }
      }
    ]
  }
}
