{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user profile (Founder, Mentor, or Investor) in TabStartup.",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "primaryRole": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "createdAt", "updatedAt"]
    },
    "Startup": {
      "title": "Startup",
      "type": "object",
      "description": "A venture profile listed on the platform.",
      "properties": {
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string", "description": "SEO friendly URL identifier." },
        "shortDescription": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "hidden"] },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "name", "slug", "status"]
    },
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "A private professional contact managed by a user.",
      "properties": {
        "ownerUid": { "type": "string" },
        "contactName": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "contactName", "createdAt", "updatedAt"]
    },
    "Deal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Deal",
      "type": "object",
      "description": "A sales or investment deal in the user's pipeline.",
      "properties": {
        "ownerUid": { "type": "string" },
        "contactId": { "type": "string" },
        "contactName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "currency": { "type": "string", "default": "USD" },
        "stage": { "type": "string", "enum": ["Lead", "Contacted", "Proposal Sent", "Won", "Lost"] },
        "probability": { "type": "number" },
        "expectedCloseDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "title", "stage", "createdAt", "updatedAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "A billing document for a contact or deal.",
      "properties": {
        "ownerUid": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "contactId": { "type": "string" },
        "contactName": { "type": "string" },
        "billFromType": { "type": "string", "enum": ["Personal", "Startup"] },
        "billFromName": { "type": "string" },
        "description": { "type": "string" },
        "paymentInstructions": { "type": "string", "description": "Manual payment instructions like bank details or mobile wallet numbers." },
        "termsAndConditions": { "type": "string", "description": "Business terms and conditions for this invoice." },
        "productType": { "type": "string", "enum": ["Digital", "Physical"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "unitPrice": { "type": "number" },
              "quantity": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Paid", "Overdue", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "A workspace task or reminder.",
      "properties": {
        "ownerUid": { "type": "string" },
        "dealId": { "type": "string" },
        "contactId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "title", "status", "priority", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/startups/{startupId}",
        "definition": { "entityName": "Startup", "schema": { "$ref": "#/backend/entities/Startup" }, "description": "Venture listings." }
      },
      {
        "path": "/contacts/{contactId}",
        "definition": { "entityName": "Contact", "schema": { "$ref": "#/backend/entities/Contact" }, "description": "Private contact records." }
      },
      {
        "path": "/deals/{dealId}",
        "definition": { "entityName": "Deal", "schema": { "$ref": "#/backend/entities/Deal" }, "description": "Private pipeline deals." }
      },
      {
        "path": "/invoices/{invoiceId}",
        "definition": { "entityName": "Invoice", "schema": { "$ref": "#/backend/entities/Invoice" }, "description": "Private billing invoices." }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": { "entityName": "Task", "schema": { "$ref": "#/backend/entities/Task" }, "description": "Private workspace tasks." }
      }
    ]
  }
}
